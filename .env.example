# === Supabase (crie um projeto NOVO em https://supabase.com/dashboard) ===
# Encontre em: Project Settings → API

# Browser (exposto ao frontend — anon key é segura, é protegida por RLS)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
VITE_SUPABASE_PROJECT_ID=SEU-PROJETO

# Server (usados por server functions no Node)
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...   # NUNCA expor ao browser
SUPABASE_PROJECT_ID=SEU-PROJETO

# === Google Contacts OAuth (opcional — Menu Configurações > Google) ===
# Console: https://console.cloud.google.com → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT=http://localhost:3000/api/google/callback

# === WhatsApp Business (opcional — provedor à sua escolha) ===
# Ex.: Meta Cloud API, Evolution API self-hosted, Twilio...
WHATSAPP_PROVIDER=evolution
WHATSAPP_API_URL=
WHATSAPP_API_KEY=

# === App ===
PORT=3000
NODE_ENV=production
SESSION_SECRET=troque-por-string-longa-aleatoria
