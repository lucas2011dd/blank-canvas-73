# =============================================================
# ConnectHub — variáveis de ambiente
# =============================================================

# === Supabase ===
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOi...
VITE_SUPABASE_PROJECT_ID=seu-projeto

SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOi...
SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
SUPABASE_PROJECT_ID=seu-projeto

# === WhatsApp Evolution API (cliente HTTP do ConnectHub) ===
WHATSAPP_PROVIDER=evolution
EVOLUTION_API_URL=http://SEU-IP:8080
EVOLUTION_API_KEY=sua-api-key
# Segredo enviado nos webhooks; se omitido usa EVOLUTION_API_KEY
EVOLUTION_WEBHOOK_SECRET=

# === Cron / Tick (/api/public/wa/tick) ===
TICK_SECRET=troque-por-um-segredo-forte
TICK_BUDGET_MS=25000
TICK_RECOVERY_MS=15000
TICK_MIGRATION_RETRY_MS=35000

# --- Watchdog anti-trava (Baileys 515 + pre-keys) ---
# Intervalo entre probes ativos por conexão (default 10 min)
WATCHDOG_INTERVAL_MS=600000
# Após quantos ms sem "last_seen_online_at" o watchdog reinicia (default 15 min)
WATCHDOG_STALE_MS=900000
# Cooldown entre restarts automáticos por conexão (default 10 min)
WATCHDOG_RESTART_COOLDOWN_MS=600000

# === Anti-restrição na migração de grupos ===
MIGRATION_MIN_DELAY_FLOOR_SECONDS=25
MIGRATION_MAX_DELAY_FLOOR_SECONDS=45
MIGRATION_RECONNECT_COOLDOWN_MS=600000
MIGRATION_MIN_INTERVAL_MS=5000

# === App ===
PORT=8080
NODE_ENV=production
SESSION_SECRET=troque-por-um-segredo-forte

# =============================================================
# ATENÇÃO — Variáveis do SERVIDOR Evolution API (não do ConnectHub)
# Configure estas no .env da Evolution API (não aqui). Elas resolvem
# o travamento conhecido do Baileys (stream:error 515 + pre-keys):
#
#   SYNC_FULL_HISTORY=false        # reduz o "tsunami" que gera timeout
#   CACHE_REDIS_ENABLED=false      # se Redis está em outro container
#   CACHE_LOCAL_ENABLED=true       # usa cache em memória (mais rápido)
#   CONFIG_SESSION_PHONE_CLIENT=ConnectHub
#
# Quando o processo travar, faça RESTART (não logout) para preservar
# a sessão sem exigir novo QR:
#   pm2 restart ApiEvolution        # (Windows/PM2)
#   docker restart evolution        # (Docker)
# =============================================================
